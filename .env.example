# Copy this file to `.env` and fill in your values:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (macOS / Linux)
#
# `.env` is gitignored — never commit real secrets.

# =============================================================================
# Chroma Cloud (required for production indexing — https://www.trychroma.com/)
# Dashboard → your database → Connect
#
# Use plain KEY=value format (no quotes or trailing commas):
#   CHROMA_API_KEY=ck-xxxxxxxx
#   CHROMA_TENANT=97466d4a-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   CHROMA_DATABASE=your-database-name
# =============================================================================
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# Optional: non-default region (default: api.trychroma.com / AWS us-east-1)
# CHROMA_HOST=europe-west1.gcp.trychroma.com
# CHROMA_PORT=443

# =============================================================================
# Vector store (optional overrides — defaults in config/vector_store.yaml)
# =============================================================================
# VECTOR_STORE_PROVIDER=chroma_cloud
# CHROMA_COLLECTION_NAME=mutual_fund_faq_chunks
# INDEX_MANIFEST_DIR=data/index

# Local dev without Chroma Cloud credentials:
# VECTOR_STORE_PROVIDER=chroma_local

# =============================================================================
# Embeddings (optional — defaults in config/embedding.yaml)
# =============================================================================
# EMBEDDING_PROVIDER=sentence_transformers
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSIONS=384
# EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# Fast tests without downloading the BGE model:
# EMBEDDING_PROVIDER=local

# =============================================================================
# Scraping (optional)
# =============================================================================
# USE_PLAYWRIGHT_FALLBACK=true
# RAW_DATA_DIR=data/raw
#
# Keep only the latest successful raw, parsed, facts, chunks, and scheduler files:
# INGESTION_KEEP_LATEST_ONLY=true

# =============================================================================
# Phase 2: RAG core (retrieval + generation)
# =============================================================================
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=
#
# OpenAI (optional alternative):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
#
# Offline / test generation without an LLM key:
# LLM_PROVIDER=template
#
# Retrieval tuning (optional — defaults in config/rag.yaml):
# RAG_DENSE_TOP_K=10
# RAG_SPARSE_TOP_K=10
# RAG_HYBRID_ALPHA=0.5
# RAG_FINAL_TOP_K=3
# RAG_RERANKER_ENABLED=true
# RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# Phase 4 / 7: API & thread store
# =============================================================================
# THREAD_STORE=sqlite
# THREAD_DB_PATH=data/threads.db
# THREAD_STORE=memory
#
# Comma-separated frontend origins allowed to call FastAPI (local / Railway):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://mutual-fund-faq-rag-ui.vercel.app
#
# Railway tip: use THREAD_STORE=memory unless a volume is mounted for SQLite.
# THREAD_STORE=memory

# =============================================================================
# Streamlit Community Cloud (free production app)
# =============================================================================
# Do not put secrets in git. Use Streamlit Cloud App settings → Secrets, or
# copy .streamlit/secrets.toml.example to .streamlit/secrets.toml for local runs.
# Public URL shape: https://<app-name>.streamlit.app  (not a FastAPI REST base URL)
#
# Optional public REST API: deploy with Dockerfile + railway.toml on Railway, then
# set Vercel VITE_API_BASE_URL to the Railway HTTPS domain (see docs/deployment-plan.md).
