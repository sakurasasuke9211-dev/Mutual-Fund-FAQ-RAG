__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example

# Scraped snapshots (regenerated by pipeline)
data/raw/**/*
!data/raw/.gitkeep

# Structured fund facts (generated)
data/facts/**/*
!data/facts/.gitkeep

# Parsed documents (generated)
data/parsed/**/*
!data/parsed/.gitkeep

# Chunk store (generated)
data/chunks/**/*
!data/chunks/.gitkeep

# Vector index (generated)
data/index/**/*
!data/index/.gitkeep
!data/index/chroma/.gitkeep

# Thread store (generated at runtime)
data/threads.db
data/threads.db-*

# Debug / local inspection artifacts
data/raw/_debug*
scripts/inspect_groww*.py

# Ingestion logs
logs/ingestion/*.log
logs/ingestion/scrape_summary_*.json
logs/ingestion/ingestion_summary_*.json
!logs/ingestion/.gitkeep

.pytest_cache/
.mypy_cache/
.ruff_cache/

# Playwright
playwright-report/
test-results/
